{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_GATEWAY_URL": "http://localhost:3001",
        "EXPO_PUBLIC_TENANT_ID": "dev-tenant"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_GATEWAY_URL": "https://rideshare-gateway-staging-fzqahweugq-uc.a.run.app",
        "EXPO_PUBLIC_TENANT_ID": ""
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_GATEWAY_URL": "https://api.urwaydispatch.com",
        "EXPO_PUBLIC_TENANT_ID": ""
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "APPLE_ID_PLACEHOLDER",
        "ascAppId": "ASC_APP_ID_PLACEHOLDER",
        "appleTeamId": "APPLE_TEAM_ID_PLACEHOLDER"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
