# ============================================================================
# UrWay Dispatch — Environment Variables
# Example only — do NOT put real secrets here. Copy to .env and fill in values.
# ============================================================================

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8080

# ── Supabase (Database & Auth) ──────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── FluidPay / PaySurity (Payment Processing) ──────────────────────────────
FLUIDPAY_BASE_URL=https://api.fluidpay.com/v1
FLUIDPAY_API_KEY=
FLUIDPAY_WEBHOOK_SECRET=
PAYSURITY_WEBHOOK_SECRET=

# ── AWS S3 (File Storage — logos, compliance docs, receipts) ────────────────
AWS_S3_BUCKET=uwd-assets
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=
AWS_CDN_BASE_URL=

# ── Twilio (SMS Notifications) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── SendGrid (Email Notifications) ─────────────────────────────────────────
SENDGRID_API_KEY=
EMAIL_FROM_ADDRESS=noreply@urwaydispatch.com
EMAIL_FROM_NAME=UrWay Dispatch

# ── Monitoring & Alerts ────────────────────────────────────────────────────
PAGERDUTY_ROUTING_KEY=
ALERT_EMAIL=ops@urwaydispatch.com
